# Copy to .env and fill in real values
NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=
MONGODB_MAX_POOL=50

CORS_ORIGINS=*

# Auth
ADMIN_PASS=
ATTEND_PASS=

# Rate limit (per IP)
RATE_WINDOW_MS=60000
RATE_MAX=300

CHECKOUT_REDIRECT_URL=http://localhost:5173/payment/return

# Session times in emails (GCP server is UTC — use your workshop timezone)
WORKSHOP_TIMEZONE=America/Vancouver
# Default length for Google Calendar invites (minutes)
WORKSHOP_DURATION_MINUTES=60
# Stable domain for calendar event IDs (do not change after go-live)
CALENDAR_UID_DOMAIN=steamoji.online

EMAIL_FROM_NAME=Steamoji Workshop
