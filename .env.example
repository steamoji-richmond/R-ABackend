# Copy to .env and fill in real values
NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb+srv://admin:password@steamoji.ohtp62h.mongodb.net/workshop?appName=steamoji
MONGODB_MAX_POOL=50

# CORS (comma-separated). Use * for open (public).
CORS_ORIGINS=*

# Auth
ADMIN_PASS=8031
ATTEND_PASS=8031

# Rate limit (per IP)
RATE_WINDOW_MS=60000
RATE_MAX=300

# Square (optional - leave blank until you have creds)
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_APPLICATION_ID=
CHECKOUT_REDIRECT_URL=http://localhost:5173/payment/return

# Gmail email sending (via App Password — no custom domain needed)
# Leave both blank to disable all outbound emails.
#
# Setup steps:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password (app: Mail, device: Other → e.g. "Workshop App")
#   4. Paste the 16-char password (no spaces) into GMAIL_APP_PASS
GMAIL_USER=you@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx
# Display name shown in the From field (optional, defaults to "Steamoji Workshop")
EMAIL_FROM_NAME=Steamoji Workshop
